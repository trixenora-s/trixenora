# Database (Neon PostgreSQL recommended for Vercel)
DATABASE_URL="postgresql://username:password@host.c.neon.tech/dbname?sslmode=require&channel_binding=require"

# Better Auth
BETTER_AUTH_SECRET="your-better-auth-secret-here"
BETTER_AUTH_URL="https://yourdomain.vercel.app"

# Optional: AI Provider Defaults (users override with their keys)
OPENAI_API_KEY="sk-proj-your-api-key-here"
ANTHROPIC_API_KEY="sk-ant-your-api-key-here"
GOOGLE_API_KEY="AIzaSy-your-api-key-here"

# App
NEXTAUTH_URL="https://yourdomain.vercel.app"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Encryption
ENCRYPTION_KEY="your-encryption-key-here-min-32-characters"
